{
  "name": "blt-agent",
  "version": "1.0.0",
  "description": "Background agent for BLT log file collection",
  "main": "agent.js",
  "scripts": {
    "start": "node agent.js",
    "install-service": "node install-service.js",
    "uninstall-service": "node uninstall-service.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "bin": "agent.js",
  
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist",
    "assets": [
      "config.json"
    ]
  }
}